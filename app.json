{
  "expo": {
    "name": "selgron-field-tech",
    "slug": "selgron-field-tech",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.selgron.fieldtech",
      "infoPlist": {
        "NSCameraUsageDescription": "A Selgron precisa da câmera para fotografar notas fiscais e atendimentos de Ordem de Serviço.",
        "NSPhotoLibraryUsageDescription": "A Selgron precisa acessar sua galeria para anexar fotos em notas fiscais e OS.",
        "NSPhotoLibraryAddUsageDescription": "A Selgron precisa salvar PDFs gerados na sua galeria."
      }
    },
    "android": {
      "package": "br.com.selgron.fieldtech",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/site-logo.png",
      "name": "Plataforma Interna - Selgron",
      "title": "Plataforma Interna - Selgron",
      "lang": "pt-BR"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "A Selgron precisa acessar sua galeria para anexar fotos.",
          "cameraPermission": "A Selgron precisa da câmera para fotografar notas e atendimentos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
